---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Home Backup Power" description="Reviews and comparisons of the best home backup power equipment — portable power stations, generators, solar, and battery backups.">
  <section class="max-w-5xl mx-auto px-4 py-20">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Home Backup Power</h1>
    <p class="text-lg text-gray-600 max-w-2xl mb-12">
      Comparison guides and reviews for portable power stations, whole-home generators,
      solar setups, and battery backups. Product guides coming soon.
    </p>
    <div class="border border-dashed border-gray-200 rounded-2xl p-12 text-center text-gray-400 text-sm">
      Product comparison pages will appear here.
    </div>
  </section>
</Layout>
