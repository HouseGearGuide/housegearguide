---
import Layout from '../../layouts/Layout.astro';
import { products } from '../../data/products';
import type { Product } from '../../data/products';

const slugOrder = ['bluetti-eb3a', 'jackery-explorer-500', 'goal-zero-yeti-500x', 'ecoflow-river-2-pro'];
const picks = slugOrder.map(slug => products.find(p => p.slug === slug)!).filter(Boolean) as Product[];
const topPick = picks[0];
---

<Layout
  title="Best Portable Power Station for Camping (2026)"
  description="The best battery-powered portable generators for camping compared: Bluetti EB3A, Jackery 500, Goal Zero Yeti 500X, and EcoFlow River 2 Pro. Silent, safe indoors, solar-ready."
>
  <div class="bg-amber-50 border-b border-amber-100">
    <div class="max-w-4xl mx-auto px-4 py-2 text-xs text-amber-800 text-center">
      This site earns commissions from purchases made through our links at no extra cost to you.
    </div>
  </div>

  <article class="max-w-4xl mx-auto px-4 py-12">

    <nav class="text-xs text-gray-400 mb-6">
      <a href="/" class="hover:text-green-700">Home</a>
      <span class="mx-2">›</span>
      <a href="/backup-power" class="hover:text-green-700">Backup Power</a>
      <span class="mx-2">›</span>
      Best Portable Generator for Camping
    </nav>

    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-3 leading-tight">
      Best Portable Power Station for Camping (2026)
    </h1>
    <p class="text-sm text-gray-400 mb-8">Last updated: April 2026 · 4 power stations compared</p>

    <p class="text-lg text-gray-700 mb-4 leading-relaxed">
      Gas generators work for camping — but they're loud, require fuel storage, produce carbon monoxide, and can't be used inside a tent, RV, or enclosed space. Battery-powered portable power stations have taken over as the go-to choice for campers, overlanders, and van lifers who want silent, safe, solar-rechargeable power anywhere.
    </p>
    <p class="text-lg text-gray-700 mb-8 leading-relaxed">
      The four picks below range from $199 to $449 and cover every camping use case — from weekend festivals to week-long off-grid trips. All are light enough to carry, all support solar input, and none produce a single decibel of engine noise.
    </p>

    <div class="bg-blue-50 border border-blue-100 rounded-2xl p-5 mb-10">
      <p class="font-semibold text-gray-900 mb-2 text-sm">What can a camping power station actually power?</p>
      <p class="text-sm text-gray-600 leading-relaxed">With 250–500Wh of capacity, these units handle: charging phones and laptops all trip (5–20 charges), running a CPAP machine through the night (8–12 hours at 30–50W), powering a small fan, running LED camp lights, and keeping a 12V cooler running for 6–12 hours. They <strong>cannot</strong> run full-size electric grills, hair dryers, or air conditioners — those require 1,000Wh+ units. Match the unit size to what you actually need to run.</p>
    </div>

    <!-- Top Pick Box -->
    <div class="bg-green-50 border border-green-200 rounded-2xl p-6 mb-10">
      <p class="text-xs font-semibold text-green-700 uppercase tracking-widest mb-3">Our Top Pick</p>
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
          <h2 class="text-xl font-bold text-gray-900 mb-1">{topPick.name}</h2>
          <p class="text-gray-600 text-sm mb-2">{topPick.tagline}</p>
          <p class="text-2xl font-bold text-green-700">${topPick.price}</p>
        </div>
        <a
          href={topPick.affiliateUrl}
          target="_blank"
          rel="nofollow noopener"
          class="inline-block bg-green-700 text-white px-6 py-3 rounded-lg font-semibold text-sm hover:bg-green-800 transition-colors whitespace-nowrap text-center"
        >
          Check Price on Amazon →
        </a>
      </div>
    </div>

    <!-- Comparison Table -->
    <h2 class="text-2xl font-bold text-gray-900 mb-4">Quick Comparison</h2>
    <div class="overflow-x-auto mb-12 rounded-xl border border-gray-100">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="text-left p-3 font-semibold text-gray-700">Power Station</th>
            <th class="text-left p-3 font-semibold text-gray-700">Price</th>
            <th class="text-left p-3 font-semibold text-gray-700">Capacity</th>
            <th class="text-left p-3 font-semibold text-gray-700">Weight</th>
            <th class="text-left p-3 font-semibold text-gray-700">Solar Input</th>
          </tr>
        </thead>
        <tbody>
          {picks.map((p, i) => (
            <tr class={`border-b border-gray-100 ${i === 0 ? 'bg-green-50' : 'hover:bg-gray-50'}`}>
              <td class="p-3">
                <a href={`#${p.slug}`} class="font-medium text-gray-900 hover:text-green-700">{p.name}</a>
                {i === 0 && <span class="ml-2 text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-medium">Top Pick</span>}
              </td>
              <td class="p-3 font-medium">${p.price}</td>
              <td class="p-3">{p.specs['Capacity']}</td>
              <td class="p-3">{p.specs['Weight']}</td>
              <td class="p-3">{p.specs['Solar Input']}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Individual Reviews -->
    {picks.map((product, i) => (
      <section id={product.slug} class="mb-16 scroll-mt-20">
        <div class="border-t border-gray-100 pt-10 mb-6">
          <p class="text-xs font-semibold text-green-700 uppercase tracking-widest mb-2">
            {i === 0 ? '🏆 Best Value for Camping' : i === 1 ? '🥈 Most Portable and Proven' : i === 2 ? '🏕️ Best for Serious Outdoors Use' : '☀️ Best Solar Input'}
          </p>
          <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
            <div>
              <h2 class="text-2xl font-bold text-gray-900 mb-1">{product.name}</h2>
              <p class="text-gray-500 text-sm">${product.price} &nbsp;·&nbsp; ⭐ {product.rating}/5</p>
            </div>
            <a
              href={product.affiliateUrl}
              target="_blank"
              rel="nofollow noopener"
              class="inline-block bg-green-700 text-white px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-green-800 transition-colors whitespace-nowrap"
            >
              Check on Amazon →
            </a>
          </div>
        </div>

        <p class="text-gray-700 mb-6 leading-relaxed">{product.tagline}</p>

        <div class="bg-gray-50 rounded-xl p-4 mb-6">
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Key Specs</p>
          <div class="grid sm:grid-cols-2 gap-x-8">
            {Object.entries(product.specs).map(([key, val]) => (
              <div class="flex justify-between py-1.5 border-b border-gray-100 last:border-0">
                <span class="text-gray-500 text-sm">{key}</span>
                <span class="font-medium text-gray-900 text-sm">{val}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-4 mb-6">
          <div class="bg-green-50 rounded-xl p-4">
            <p class="font-semibold text-gray-900 mb-3 text-sm">Pros</p>
            <ul class="space-y-2">
              {product.pros.map(pro => (
                <li class="text-sm text-gray-700 flex gap-2">
                  <span class="text-green-600 flex-shrink-0 mt-0.5">✓</span>
                  {pro}
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-red-50 rounded-xl p-4">
            <p class="font-semibold text-gray-900 mb-3 text-sm">Cons</p>
            <ul class="space-y-2">
              {product.cons.map(con => (
                <li class="text-sm text-gray-700 flex gap-2">
                  <span class="text-red-500 flex-shrink-0 mt-0.5">✗</span>
                  {con}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <a
          href={product.affiliateUrl}
          target="_blank"
          rel="nofollow noopener"
          class="inline-block border border-green-700 text-green-700 px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-green-700 hover:text-white transition-colors"
        >
          Buy {product.name} on Amazon →
        </a>
      </section>
    ))}

    <!-- Buying Guide -->
    <section class="border-t border-gray-100 pt-10 mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Choosing the Right Camping Power Station</h2>
      <div class="space-y-6 text-gray-700">
        <div>
          <h3 class="font-bold text-gray-900 mb-2">Calculate your actual watt-hour needs first</h3>
          <p class="text-sm leading-relaxed">Before buying, add up what you'll actually run. A smartphone charges from 0–100% using ~15Wh. A MacBook Pro charges overnight using ~60Wh. A CPAP machine without humidifier runs 8 hours at ~30W = 240Wh. An LED camp lantern runs 10 hours at 5W = 50Wh. Add 20% buffer for efficiency losses. That total is your minimum capacity. For a weekend trip with all the above: ~365Wh — the Jackery 500 covers it; the Bluetti EB3A covers it with a little margin.</p>
        </div>
        <div>
          <h3 class="font-bold text-gray-900 mb-2">Solar recharging: realistic expectations</h3>
          <p class="text-sm leading-relaxed">A 100W solar panel in ideal conditions (full sun, optimal angle) produces ~80W of actual power after losses. A 500Wh unit recharges in 500/80 = ~6.25 hours of peak sun — but you rarely get 6 peak-sun-hours in a day. Expect 4–5 peak hours realistically, meaning a full recharge takes 2 days of normal camping. For off-grid trips over 3+ days, either buy a high-solar-input unit (EcoFlow River 2 Pro at 500W) or carry a second panel.</p>
        </div>
        <div>
          <h3 class="font-bold text-gray-900 mb-2">LFP vs NMC battery chemistry for camping</h3>
          <p class="text-sm leading-relaxed">LiFePO4 (LFP) batteries are safer and more temperature-stable than NMC — a meaningful difference when stored in a hot car or used in fluctuating outdoor temperatures. LFP also lasts 3,000–3,500 cycles vs ~500 for NMC, meaning a daily-use camper gets 8–10 years of life vs 1–2. The Bluetti EB3A and EcoFlow River 2 Pro both use LFP. The Jackery 500 and Goal Zero Yeti 500X use NMC, which is adequate for occasional camping but degrades faster with heavy use.</p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="border-t border-gray-100 pt-10 mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Frequently Asked Questions</h2>
      <div class="space-y-6">
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">Can I use these inside a tent or RV?</h3>
          <p class="text-sm text-gray-600 leading-relaxed">Yes — battery power stations produce no exhaust and are completely safe to use indoors. This is the key advantage over gas generators, which cannot be operated in enclosed spaces due to carbon monoxide risk. You can run one at full load inside a tent, van, or RV without any ventilation requirements.</p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">Can I fly with a portable power station?</h3>
          <p class="text-sm text-gray-600 leading-relaxed">The FAA limits carry-on batteries to 100Wh for unrestricted use, and allows 101–160Wh with airline approval. All four units on this page exceed 160Wh and cannot be taken on planes — neither as carry-on nor checked baggage. Drive or ship them to your destination. This is the one area where smaller power banks (under 100Wh) have an advantage for air travel.</p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">How do I protect a power station in the rain?</h3>
          <p class="text-sm text-gray-600 leading-relaxed">None of these units are waterproof. Keep them inside your tent or vehicle during rain. If you're running a solar panel outside, position the power station just inside a tent doorway with the input cable running out to the panel. Short exposure to light rain (while recharging) is unlikely to cause damage, but don't leave them in direct rain for extended periods.</p>
        </div>
      </div>
    </section>

    <!-- Related Guides -->
    <section class="border-t border-gray-100 pt-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Related Guides</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        <a href="/backup-power/best-solar-generator-home-backup" class="group block border border-gray-100 rounded-xl p-4 hover:border-green-200 hover:shadow-sm transition-all">
          <p class="text-xs text-green-700 font-semibold uppercase tracking-widest mb-1">Backup Power</p>
          <p class="font-medium text-gray-900 text-sm group-hover:text-green-700 transition-colors">Best Solar Generators for Home Backup →</p>
        </a>
        <a href="/backup-power/solar-generator-vs-portable-generator" class="group block border border-gray-100 rounded-xl p-4 hover:border-green-200 hover:shadow-sm transition-all">
          <p class="text-xs text-green-700 font-semibold uppercase tracking-widest mb-1">Backup Power</p>
          <p class="font-medium text-gray-900 text-sm group-hover:text-green-700 transition-colors">Solar Generator vs Gas Generator: Which to Choose? →</p>
        </a>
      </div>
    </section>

  </article>
</Layout>
