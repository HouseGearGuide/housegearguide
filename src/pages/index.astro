---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="Expert reviews and comparisons for smart home devices and home backup power equipment. Built for homeowners who want honest, researched buying advice.">

  <!-- Hero -->
  <section class="bg-gray-50 border-b border-gray-100">
    <div class="max-w-5xl mx-auto px-4 py-20 text-center">
      <p class="text-sm font-semibold text-green-700 uppercase tracking-widest mb-4">Gear Guides for Homeowners</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight mb-6">
        The Right Gear for Your Home,<br class="hidden sm:block" /> Researched and Ranked
      </h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-10">
        HouseGearGuide covers two categories homeowners care about most: smart home devices and backup power equipment.
        No fluff — just honest comparisons, clear specs, and picks that hold up in real life.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/smart-home" class="inline-block bg-green-700 text-white px-6 py-3 rounded-lg font-semibold hover:bg-green-800 transition-colors">
          Browse Smart Home
        </a>
        <a href="/backup-power" class="inline-block bg-white text-gray-900 border border-gray-200 px-6 py-3 rounded-lg font-semibold hover:bg-gray-50 transition-colors">
          Browse Backup Power
        </a>
        <a href="/backup-power/calculator" class="inline-block bg-amber-500 text-white px-6 py-3 rounded-lg font-semibold hover:bg-amber-600 transition-colors">
          Backup Power Calculator
        </a>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="max-w-5xl mx-auto px-4 py-20">
    <h2 class="text-2xl font-bold text-gray-900 mb-10 text-center">What We Cover</h2>
    <div class="grid sm:grid-cols-2 gap-8">

      <a href="/smart-home" class="group block border border-gray-100 rounded-2xl p-8 hover:border-green-200 hover:shadow-md transition-all">
        <div class="text-3xl mb-4">&#127968;</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-green-700 transition-colors">Smart Home Devices</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          Smart locks, thermostats, security cameras, lighting systems, and more.
          We break down what's worth buying and what's overhyped.
        </p>
      </a>

      <a href="/backup-power" class="group block border border-gray-100 rounded-2xl p-8 hover:border-green-200 hover:shadow-md transition-all">
        <div class="text-3xl mb-4">&#9889;</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-green-700 transition-colors">Home Backup Power</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          Portable power stations, whole-home generators, solar setups, and battery backups.
          Practical picks for keeping the lights on when the grid goes down.
        </p>
      </a>

    </div>
  </section>

  <!-- Featured Guides -->
  <section class="border-t border-gray-100">
    <div class="max-w-5xl mx-auto px-4 py-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-2 text-center">Latest Buying Guides</h2>
      <p class="text-center text-sm text-gray-500 mb-10">Detailed comparisons for the most common homeowner questions.</p>
      <div class="grid sm:grid-cols-3 gap-6">
        <a href="/backup-power/best-portable-power-station-under-500" class="group block border border-gray-100 rounded-2xl p-6 hover:border-green-200 hover:shadow-md transition-all">
          <p class="text-xs font-semibold text-green-700 uppercase tracking-widest mb-2">Backup Power</p>
          <h3 class="font-bold text-gray-900 mb-2 group-hover:text-green-700 transition-colors text-sm leading-snug">Best Portable Power Stations Under $500</h3>
          <p class="text-xs text-gray-500 leading-relaxed">5 models compared. EcoFlow DELTA 2 is our top pick — 1024Wh of LFP capacity at the $500 ceiling.</p>
        </a>
        <a href="/smart-home/best-smart-thermostat-no-c-wire" class="group block border border-gray-100 rounded-2xl p-6 hover:border-green-200 hover:shadow-md transition-all">
          <p class="text-xs font-semibold text-green-700 uppercase tracking-widest mb-2">Smart Home</p>
          <h3 class="font-bold text-gray-900 mb-2 group-hover:text-green-700 transition-colors text-sm leading-snug">Best Smart Thermostats for Homes Without C-Wire</h3>
          <p class="text-xs text-gray-500 leading-relaxed">3 picks that work in older homes — no electrician, no new wiring required.</p>
        </a>
        <a href="/smart-home/best-smart-lock-for-renters" class="group block border border-gray-100 rounded-2xl p-6 hover:border-green-200 hover:shadow-md transition-all">
          <p class="text-xs font-semibold text-green-700 uppercase tracking-widest mb-2">Smart Home</p>
          <h3 class="font-bold text-gray-900 mb-2 group-hover:text-green-700 transition-colors text-sm leading-snug">Best Smart Locks for Renters</h3>
          <p class="text-xs text-gray-500 leading-relaxed">4 options that won't violate your lease — including one your landlord will never notice.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="border-t border-gray-100 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4 py-12">
      <div class="grid sm:grid-cols-3 gap-8 text-center text-sm text-gray-600">
        <div>
          <p class="text-2xl font-bold text-gray-900 mb-1">Spec-Driven</p>
          <p>Every comparison is built on real product data, not marketing copy.</p>
        </div>
        <div>
          <p class="text-2xl font-bold text-gray-900 mb-1">No Sponsored Rankings</p>
          <p>Picks are ranked on merit. Affiliate links don't change our recommendations.</p>
        </div>
        <div>
          <p class="text-2xl font-bold text-gray-900 mb-1">Built for Homeowners</p>
          <p>We write for people who own homes, not tech enthusiasts chasing specs.</p>
        </div>
      </div>
    </div>
  </section>

</Layout>
