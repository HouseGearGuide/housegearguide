---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Smart Home Devices" description="Reviews and comparisons of the best smart home devices for homeowners — locks, thermostats, cameras, and more.">
  <section class="max-w-5xl mx-auto px-4 py-20">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Smart Home Devices</h1>
    <p class="text-lg text-gray-600 max-w-2xl mb-12">
      Comparison guides and reviews for smart locks, thermostats, security cameras, lighting, and more.
      Product guides coming soon.
    </p>
    <div class="border border-dashed border-gray-200 rounded-2xl p-12 text-center text-gray-400 text-sm">
      Product comparison pages will appear here.
    </div>
  </section>
</Layout>
