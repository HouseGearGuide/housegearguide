---
import Layout from '../../layouts/Layout.astro';
import { products } from '../../data/products';

const slugOrder = [
  'ring-smart-floodlight-battery',
  'govee-outdoor-flood-lights',
  'philips-hue-lily-outdoor',
  'govee-outdoor-string-lights',
  'kasa-outdoor-string-lights',
];

const picks = slugOrder.map(slug => products.find(p => p.slug === slug)!);
const topPick = picks[0];

const powerSource: Record<string, string> = {
  'ring-smart-floodlight-battery': 'Rechargeable Battery',
  'govee-outdoor-flood-lights': 'Plug-In (Outdoor Outlet)',
  'philips-hue-lily-outdoor': 'Low-Voltage Wired',
  'govee-outdoor-string-lights': 'Plug-In (Outdoor Outlet)',
  'kasa-outdoor-string-lights': 'Plug-In (Outdoor Outlet)',
};

const useCase: Record<string, string> = {
  'ring-smart-floodlight-battery': 'Security / Motion-Activated',
  'govee-outdoor-flood-lights': 'Color Accent / Landscape',
  'philips-hue-lily-outdoor': 'Premium Landscape Spotlight',
  'govee-outdoor-string-lights': 'Patio / Deck Ambiance',
  'kasa-outdoor-string-lights': 'Patio / Deck Ambiance',
};
---

<Layout
  title="Best Smart Outdoor Lights for Your Home (2025) — Battery, Solar & Plug-In Options"
  description="The best smart outdoor lights for security, ambiance, and landscaping. Covers battery-powered floodlights, plug-in string lights, and landscape spotlights with honest pros and cons."
>
  <div class="max-w-4xl mx-auto px-4 py-8">

    <!-- FTC Disclosure -->
    <div class="bg-yellow-50 border border-yellow-200 rounded-md p-3 mb-6 text-sm text-yellow-800">
      <strong>Disclosure:</strong> HouseGearGuide earns a commission if you buy through our links — at no cost to you. We only recommend products we've researched thoroughly.
    </div>

    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:underline">Home</a> &rsaquo;
      <a href="/smart-home/" class="hover:underline">Smart Home</a> &rsaquo;
      <span class="text-gray-700">Best Smart Outdoor Lights</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-4">Best Smart Outdoor Lights (2025)</h1>

    <p class="text-lg text-gray-700 mb-6">
      Smart outdoor lights fall into three practical categories: <strong>battery-powered security floodlights</strong> that install anywhere without running wire, <strong>plug-in smart string lights</strong> for patio ambiance, and <strong>low-voltage landscape spotlights</strong> for accent and pathway lighting. This guide covers the best options in each — so you can pick based on where you need light and whether you have an outdoor outlet.
    </p>

    <!-- Top Pick Box -->
    <div class="bg-green-50 border border-green-200 rounded-lg p-5 mb-8">
      <div class="text-sm font-semibold text-green-700 uppercase tracking-wide mb-1">Top Pick — Best for Most Homes</div>
      <div class="text-xl font-bold text-gray-900 mb-1">{topPick.name}</div>
      <p class="text-gray-700 text-sm mb-3">{topPick.tagline}</p>
      <div class="flex items-center gap-4">
        <span class="text-2xl font-bold text-green-700">${topPick.price}</span>
        <a href={topPick.affiliateUrl} target="_blank" rel="nofollow noopener" class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-5 py-2 rounded-md text-sm transition-colors">
          View on Amazon →
        </a>
      </div>
    </div>

    <!-- Comparison Table -->
    <h2 class="text-2xl font-bold text-gray-900 mb-4">Quick Comparison</h2>
    <div class="overflow-x-auto mb-10">
      <table class="w-full text-sm border-collapse border border-gray-200">
        <thead class="bg-gray-100">
          <tr>
            <th class="border border-gray-200 px-3 py-2 text-left">Light</th>
            <th class="border border-gray-200 px-3 py-2 text-left">Power Source</th>
            <th class="border border-gray-200 px-3 py-2 text-left">Best Use</th>
            <th class="border border-gray-200 px-3 py-2 text-left">Smart Platform</th>
            <th class="border border-gray-200 px-3 py-2 text-left">Price</th>
            <th class="border border-gray-200 px-3 py-2 text-left">Link</th>
          </tr>
        </thead>
        <tbody>
          {picks.map((p, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
              <td class="border border-gray-200 px-3 py-2 font-medium">{p.name}</td>
              <td class="border border-gray-200 px-3 py-2">{powerSource[p.slug]}</td>
              <td class="border border-gray-200 px-3 py-2">{useCase[p.slug]}</td>
              <td class="border border-gray-200 px-3 py-2">{p.specs['Smart Platforms'] || p.specs['Smart Platform'] || '—'}</td>
              <td class="border border-gray-200 px-3 py-2">${p.price}</td>
              <td class="border border-gray-200 px-3 py-2">
                <a href={p.affiliateUrl} target="_blank" rel="nofollow noopener" class="text-blue-600 hover:underline font-medium">Amazon →</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Info Box -->
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-8 text-sm text-blue-900">
      <strong>Which power type is right for you?</strong>
      <ul class="mt-2 space-y-1 list-disc list-inside">
        <li><strong>No outdoor outlet nearby?</strong> — Go battery-powered. Ring Floodlight Battery installs with two screws anywhere.</li>
        <li><strong>Have an outdoor outlet on your patio?</strong> — Plug-in string lights or Govee flood lights give you more brightness and color options.</li>
        <li><strong>Landscaping beds or pathways?</strong> — Low-voltage wired landscape spotlights (Philips Hue Lily) look the cleanest and last longest.</li>
      </ul>
    </div>

    <!-- Individual Product Reviews -->
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Full Reviews</h2>

    {picks.map((p, i) => (
      <div class="border border-gray-200 rounded-lg p-6 mb-6">
        <div class="flex items-start justify-between gap-4 mb-3">
          <div>
            <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">#{i + 1} — {useCase[p.slug]}</div>
            <h3 class="text-xl font-bold text-gray-900">{p.name}</h3>
            <p class="text-gray-600 text-sm mt-1">{p.tagline}</p>
          </div>
          <div class="text-right flex-shrink-0">
            <div class="text-2xl font-bold text-green-700">${p.price}</div>
            <div class="text-xs text-gray-500 mt-0.5">{powerSource[p.slug]}</div>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3 text-sm mb-4">
          {Object.entries(p.specs).map(([key, val]) => (
            <div class="bg-gray-50 rounded px-3 py-1.5">
              <span class="font-medium text-gray-700">{key}:</span> {val}
            </div>
          ))}
        </div>

        <div class="grid md:grid-cols-2 gap-4 mb-4">
          <div>
            <div class="font-semibold text-green-700 mb-1 text-sm">Pros</div>
            <ul class="text-sm space-y-1">
              {p.pros.map(pro => <li class="flex gap-1.5"><span class="text-green-500 mt-0.5">✓</span><span>{pro}</span></li>)}
            </ul>
          </div>
          <div>
            <div class="font-semibold text-red-600 mb-1 text-sm">Cons</div>
            <ul class="text-sm space-y-1">
              {p.cons.map(con => <li class="flex gap-1.5"><span class="text-red-400 mt-0.5">✗</span><span>{con}</span></li>)}
            </ul>
          </div>
        </div>

        <a href={p.affiliateUrl} target="_blank" rel="nofollow noopener" class="inline-block bg-orange-500 hover:bg-orange-600 text-white font-semibold px-5 py-2 rounded-md text-sm transition-colors">
          Check Price on Amazon →
        </a>
      </div>
    ))}

    <!-- Buying Guide -->
    <div class="bg-gray-50 rounded-lg p-6 mb-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">How to Choose Smart Outdoor Lights</h2>

      <h3 class="text-lg font-semibold text-gray-800 mb-2">Security vs. Ambiance</h3>
      <p class="text-gray-700 text-sm mb-4">
        Security lights are motion-activated, bright (700–1500 lumens), and designed to deter intruders. Ambiance lights — string lights, landscape spotlights — are dimmer and focused on color, warmth, and mood. Most homeowners need both; buy security first, then add ambiance.
      </p>

      <h3 class="text-lg font-semibold text-gray-800 mb-2">Ecosystem Compatibility</h3>
      <p class="text-gray-700 text-sm mb-4">
        Ring lights only work with Ring and Alexa. Philips Hue works with everything — Alexa, Google, Apple HomeKit, SmartThings. Govee and Kasa work with Alexa and Google but not HomeKit. If you're an Apple HomeKit household, Philips Hue is the only outdoor smart light brand worth considering.
      </p>

      <h3 class="text-lg font-semibold text-gray-800 mb-2">Weather Rating</h3>
      <p class="text-gray-700 text-sm mb-4">
        IP65 means dust-tight and rain resistant — fine for most climates. IP55 (Ring Floodlight Battery) is still weather-resistant but avoids direct water jets. All products on this list are rated for outdoor use year-round in typical North American climates.
      </p>
    </div>

    <!-- Related Guides -->
    <div class="border-t border-gray-200 pt-6">
      <h2 class="text-lg font-bold text-gray-900 mb-3">Related Guides</h2>
      <ul class="space-y-2 text-sm">
        <li>→ <a href="/smart-home/best-smart-lighting-outdoor-spaces/" class="text-blue-600 hover:underline">Best Smart Outdoor Lighting for All Spaces</a></li>
        <li>→ <a href="/smart-home/best-outdoor-security-camera-system/" class="text-blue-600 hover:underline">Best Outdoor Security Camera Systems</a></li>
        <li>→ <a href="/smart-home/best-smart-home-security-system-under-500/" class="text-blue-600 hover:underline">Best Smart Home Security Systems Under $500</a></li>
      </ul>
    </div>

  </div>
</Layout>
