---
import Layout from '../../layouts/Layout.astro';
import { products } from '../../data/products';

const slugOrder = [
  'amazon-echo-dot-5th-gen',
  'august-wifi-smart-lock-4th-gen',
  'wyze-cam-v4',
  'kasa-smart-bulb-kl135',
  'kasa-outdoor-smart-plug-ep40a',
];

const picks = slugOrder.map(slug => products.find(p => p.slug === slug)!);
const topPick = picks[0];

const renterFriendly: Record<string, string> = {
  'amazon-echo-dot-5th-gen': 'Yes — no install',
  'august-wifi-smart-lock-4th-gen': 'Yes — interior only, no exterior changes',
  'wyze-cam-v4': 'Yes — no drilling, just plug in',
  'kasa-smart-bulb-kl135': 'Yes — replace bulb, take it when you leave',
  'kasa-outdoor-smart-plug-ep40a': 'Yes — plug in, unplug when moving',
};
---

<Layout
  title="Best Smart Home Devices for Apartments (2025) — Renter-Friendly Picks"
  description="The best smart home devices for apartment renters — no drilling, no permanent changes, no lost security deposits. Covers voice assistants, smart locks, cameras, bulbs, and plugs."
>
  <div class="max-w-4xl mx-auto px-4 py-8">

    <!-- FTC Disclosure -->
    <div class="bg-yellow-50 border border-yellow-200 rounded-md p-3 mb-6 text-sm text-yellow-800">
      <strong>Disclosure:</strong> HouseGearGuide earns a commission if you buy through our links — at no cost to you. We only recommend products we've researched thoroughly.
    </div>

    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:underline">Home</a> &rsaquo;
      <a href="/smart-home/" class="hover:underline">Smart Home</a> &rsaquo;
      <span class="text-gray-700">Best Smart Home Devices for Apartments</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-4">Best Smart Home Devices for Apartments (2025)</h1>

    <p class="text-lg text-gray-700 mb-6">
      Building a smart apartment is different from building a smart house. Every device has to work without drilling studs, running new wire, or modifying anything a landlord would notice. The good news: the best smart home upgrades for renters require zero permanent changes and move with you when your lease ends.
    </p>

    <!-- Renter Rules Box -->
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6 text-sm text-amber-900">
      <strong>The Renter's Rule for Every Device:</strong> If you can't return the apartment to its original state in under 20 minutes, it's the wrong device. Every pick on this list passes that test.
    </div>

    <!-- Top Pick Box -->
    <div class="bg-green-50 border border-green-200 rounded-lg p-5 mb-8">
      <div class="text-sm font-semibold text-green-700 uppercase tracking-wide mb-1">Start Here — The Hub for Any Smart Apartment</div>
      <div class="text-xl font-bold text-gray-900 mb-1">{topPick.name}</div>
      <p class="text-gray-700 text-sm mb-3">{topPick.tagline}</p>
      <div class="flex items-center gap-4">
        <span class="text-2xl font-bold text-green-700">${topPick.price}</span>
        <a href={topPick.affiliateUrl} target="_blank" rel="nofollow noopener" class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-5 py-2 rounded-md text-sm transition-colors">
          View on Amazon →
        </a>
      </div>
    </div>

    <!-- Comparison Table -->
    <h2 class="text-2xl font-bold text-gray-900 mb-4">Quick Comparison</h2>
    <div class="overflow-x-auto mb-10">
      <table class="w-full text-sm border-collapse border border-gray-200">
        <thead class="bg-gray-100">
          <tr>
            <th class="border border-gray-200 px-3 py-2 text-left">Device</th>
            <th class="border border-gray-200 px-3 py-2 text-left">Category</th>
            <th class="border border-gray-200 px-3 py-2 text-left">Renter-Friendly</th>
            <th class="border border-gray-200 px-3 py-2 text-left">Smart Platform</th>
            <th class="border border-gray-200 px-3 py-2 text-left">Price</th>
            <th class="border border-gray-200 px-3 py-2 text-left">Link</th>
          </tr>
        </thead>
        <tbody>
          {picks.map((p, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
              <td class="border border-gray-200 px-3 py-2 font-medium">{p.name}</td>
              <td class="border border-gray-200 px-3 py-2">{p.category === 'smart-home' ? p.tagline.split('—')[0].trim() : p.tagline}</td>
              <td class="border border-gray-200 px-3 py-2 text-green-700 font-medium">{renterFriendly[p.slug]}</td>
              <td class="border border-gray-200 px-3 py-2">{p.specs['Smart Platforms'] || p.specs['Smart Platform'] || p.specs['Connectivity'] || '—'}</td>
              <td class="border border-gray-200 px-3 py-2">${p.price}</td>
              <td class="border border-gray-200 px-3 py-2">
                <a href={p.affiliateUrl} target="_blank" rel="nofollow noopener" class="text-blue-600 hover:underline font-medium">Amazon →</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Individual Product Reviews -->
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Full Reviews</h2>

    {picks.map((p, i) => (
      <div class="border border-gray-200 rounded-lg p-6 mb-6">
        <div class="flex items-start justify-between gap-4 mb-3">
          <div>
            <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">#{i + 1} — Renter-Friendly: {renterFriendly[p.slug]}</div>
            <h3 class="text-xl font-bold text-gray-900">{p.name}</h3>
            <p class="text-gray-600 text-sm mt-1">{p.tagline}</p>
          </div>
          <div class="text-right flex-shrink-0">
            <div class="text-2xl font-bold text-green-700">${p.price}</div>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3 text-sm mb-4">
          {Object.entries(p.specs).map(([key, val]) => (
            <div class="bg-gray-50 rounded px-3 py-1.5">
              <span class="font-medium text-gray-700">{key}:</span> {val}
            </div>
          ))}
        </div>

        <div class="grid md:grid-cols-2 gap-4 mb-4">
          <div>
            <div class="font-semibold text-green-700 mb-1 text-sm">Pros</div>
            <ul class="text-sm space-y-1">
              {p.pros.map(pro => <li class="flex gap-1.5"><span class="text-green-500 mt-0.5">✓</span><span>{pro}</span></li>)}
            </ul>
          </div>
          <div>
            <div class="font-semibold text-red-600 mb-1 text-sm">Cons</div>
            <ul class="text-sm space-y-1">
              {p.cons.map(con => <li class="flex gap-1.5"><span class="text-red-400 mt-0.5">✗</span><span>{con}</span></li>)}
            </ul>
          </div>
        </div>

        <a href={p.affiliateUrl} target="_blank" rel="nofollow noopener" class="inline-block bg-orange-500 hover:bg-orange-600 text-white font-semibold px-5 py-2 rounded-md text-sm transition-colors">
          Check Price on Amazon →
        </a>
      </div>
    ))}

    <!-- Buying Guide -->
    <div class="bg-gray-50 rounded-lg p-6 mb-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Building a Smart Apartment — The Right Order</h2>

      <h3 class="text-lg font-semibold text-gray-800 mb-2">Step 1: Voice Assistant First ($30–50)</h3>
      <p class="text-gray-700 text-sm mb-4">
        The Echo Dot is the brain. Buy it before anything else. It connects everything, lets you control devices by voice, and runs Alexa routines — like turning off all lights when you say "good night." If you'd rather stay in the Google ecosystem, the Nest Mini is the equivalent alternative.
      </p>

      <h3 class="text-lg font-semibold text-gray-800 mb-2">Step 2: Smart Bulbs in One Room ($20–30)</h3>
      <p class="text-gray-700 text-sm mb-4">
        Start with the room you use most — usually the bedroom or living room. Smart bulbs screw in where regular bulbs are. When you move, unscrew them and bring them with you. Kasa bulbs work well with Alexa and Google and come in color or tunable white versions.
      </p>

      <h3 class="text-lg font-semibold text-gray-800 mb-2">Step 3: Smart Lock for Keyless Entry ($150–200)</h3>
      <p class="text-gray-700 text-sm mb-4">
        The August Wi-Fi Smart Lock fits over your existing deadbolt interior without changing a single thing on the exterior side. Your landlord doesn't need to know it exists. You'll never fumble for keys again, and you can give temporary access to guests or dog walkers via the app.
      </p>

      <h3 class="text-lg font-semibold text-gray-800 mb-2">Step 4: Indoor Camera for Security ($25–35)</h3>
      <p class="text-gray-700 text-sm mb-4">
        The Wyze Cam v4 is the best value indoor camera — under $35, 2.5K resolution, sits on any surface, and requires no drilling. Point it at your front door from inside, or use it to check on pets when you're out.
      </p>

      <div class="bg-white border border-gray-200 rounded-lg p-4 mt-4 text-sm">
        <div class="font-semibold text-gray-800 mb-2">Total Budget Breakdown</div>
        <ul class="space-y-1 text-gray-700">
          <li class="flex justify-between"><span>Echo Dot 5th Gen</span><span class="font-medium">$35</span></li>
          <li class="flex justify-between"><span>Kasa Smart Bulb (2-pack)</span><span class="font-medium">$22</span></li>
          <li class="flex justify-between"><span>Wyze Cam v4</span><span class="font-medium">$34</span></li>
          <li class="flex justify-between"><span>Kasa Outdoor Smart Plug</span><span class="font-medium">$20</span></li>
          <li class="flex justify-between border-t border-gray-200 pt-1 mt-1"><span class="font-semibold">Subtotal (excluding lock)</span><span class="font-semibold text-green-700">~$111</span></li>
          <li class="flex justify-between"><span>+ August Smart Lock</span><span class="font-medium">$179</span></li>
          <li class="flex justify-between border-t border-gray-200 pt-1 mt-1"><span class="font-semibold">Full apartment starter kit</span><span class="font-semibold text-green-700">~$290</span></li>
        </ul>
      </div>
    </div>

    <!-- Related Guides -->
    <div class="border-t border-gray-200 pt-6">
      <h2 class="text-lg font-bold text-gray-900 mb-3">Related Guides</h2>
      <ul class="space-y-2 text-sm">
        <li>→ <a href="/smart-home/best-smart-lock-for-renters/" class="text-blue-600 hover:underline">Best Smart Locks for Renters</a></li>
        <li>→ <a href="/smart-home/best-smart-home-devices-for-renters/" class="text-blue-600 hover:underline">Best Smart Home Devices for Renters</a></li>
        <li>→ <a href="/smart-home/best-smart-home-starter-kit-under-200/" class="text-blue-600 hover:underline">Best Smart Home Starter Kits Under $200</a></li>
      </ul>
    </div>

  </div>
</Layout>
